# Environment files
.env
.env.*
.envrc

# Virtualenv / Python cache
.venv/
__pycache__/
*.py[cod]

# Local session/state and data snapshots
*.session
*.session-journal
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.log

# Shared Codex setup should be versioned
!.agents/
!.agents/**

# Ignore local Codex state by default
.codex/*

# But keep shared project config and shared agents
!.codex/config.toml
!.codex/agents/
!.codex/agents/**

# Secrets, credentials, and private key material
*.pem
*.key
*.p12
*.pfx
*.kdbx
*.secret
*.secrets
secrets.*
credentials.*
*.token

# Local overrides / temporary files / backups
*.bak
*.tmp
*.swp
*~
.local

# Editor / OS files
.DS_Store
.idea/
.vscode/

# Python tooling / build output
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/
